# Discord Bot Token (from Discord Developer Portal)
DISCORD_TOKEN=your_bot_token_here

# Your Application/Client ID
CLIENT_ID=your_client_id_here

# Guild ID (your server ID) — used for command deployment
GUILD_ID=your_guild_id_here

# Comma-separated list of owner Discord user IDs
OWNER_IDS=123456789012345678,987654321098765432

# The name of the whitelist role that can use bot commands
WHITELIST_ROLE_NAME=Bot Access

# The name of the jail/cage role (must exist in your server)
JAIL_ROLE_NAME=Caged

# Channel ID where cage/strip logs are sent
LOG_CHANNEL_ID=your_log_channel_id_here
